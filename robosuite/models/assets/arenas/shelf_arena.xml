<mujoco model="shelf_arena">
  <asset>
    <!-- 复用原有资产 -->
    <texture builtin="gradient" height="256" rgb1=".9 .9 1." rgb2=".2 .3 .4" type="skybox" width="256"/>
    <texture file="../textures/light-gray-floor-tile.png" type="2d" name="texplane"/>
    <material name="floorplane" reflectance="0.01" shininess="0.0" specular="0.0" texrepeat="2 2" texture="texplane" texuniform="true"/>
    
    <!-- 陶瓷材质 (用于货架隔板) -->
    <texture file="../textures/ceramic.png" type="cube" name="tex-ceramic"/>
    <material name="shelf_ceramic" reflectance="0.0" shininess="0.0" specular="0.2" texrepeat="1 1" texture="tex-ceramic" />
    
    <!-- 钢材材质 (用于货架立柱) -->
    <texture file="../textures/steel-brushed.png" type="cube" name="tex-steel-brushed"/>
    <material name="shelf_legs_metal" reflectance="0.8" shininess="0.8" texrepeat="1 1" texture="tex-steel-brushed" />
    
    <!-- 墙壁材质 -->
    <texture file="../textures/light-gray-plaster.png" type="2d" name="tex-light-gray-plaster"/>
    <material name="walls_mat" reflectance="0.0" shininess="0.1" specular="0.1" texrepeat="3 3" texture="tex-light-gray-plaster" texuniform="true" />
    
    <!-- 备用材质 -->
    <texture name="textshelf" builtin="flat" height="512" width="512" rgb1="0.5 0.5 0.5" rgb2="0.5 0.5 0.5"/>
    <material name="shelf_mat" texture="textshelf" />
  </asset>

  <worldbody>
    <!-- Floor (不变) -->
    <geom condim="3" group="1" material="floorplane" name="floor" pos="0 0 0" size="3 3 .125" type="plane"/>
    
    <!-- Walls (不变) -->
    <geom pos="-1.25 2.25 1.5" quat="0.6532815 0.6532815 0.2705981 0.2705981" size="1.06 1.5 0.01" type="box" conaffinity="0" contype="0" group="1" name="wall_leftcorner_visual" material="walls_mat"/>
    <geom pos="-1.25 -2.25 1.5" quat="0.6532815 0.6532815 -0.2705981 -0.2705981" size="1.06 1.5 0.01" type="box" conaffinity="0" contype="0" group="1" name="wall_rightcorner_visual" material="walls_mat"/>
    <geom pos="1.25 3 1.5" quat="0.7071 0.7071 0 0" size="1.75 1.5 0.01" type="box" conaffinity="0" contype="0" group="1" name="wall_left_visual" material="walls_mat"/>
    <geom pos="1.25 -3 1.5" quat="0.7071 -0.7071 0 0" size="1.75 1.5 0.01" type="box" conaffinity="0" contype="0" group="1" name="wall_right_visual" material="walls_mat"/>
    <geom pos="-2 0 1.5" quat="0.5 0.5 0.5 0.5" size="1.5 1.5 0.01" type="box" conaffinity="0" contype="0" group="1" name="wall_rear_visual" material="walls_mat"/>
    <geom pos="3 0 1.5" quat="0.5 0.5 -0.5 -0.5" size="3 1.5 0.01" type="box" conaffinity="0" contype="0" group="1" name="wall_front_visual" material="walls_mat"/>

    <!-- ================= 货架主体 (替换桌子) ================= -->
    <!-- 
       原桌子尺寸: size="0.4 0.4 0.4" (总宽0.8, 总深0.8, 总高0.8), 中心 pos="0 0 0.4"
       新货架设计: 
       - 总宽 0.8m, 总深 0.8m, 总高 0.8m
       - 立柱: 4根, 位于四角
       - 隔板: 3层 (底, 中, 顶)
    -->
    <body name="shelf" pos="0 0 0">

      <!-- === 1. 碰撞体 (Collision) - 简化为一个整体或分块，这里分块以支持物体放置 === -->
      
      <!-- 4根立柱 (碰撞) -->
      <geom name="shelf_leg_1_col" pos="-0.38 -0.18 0.4" size="0.02 0.02 1.5" type="box" group="0" friction="1 0.005 0.0001"/>
      <geom name="shelf_leg_2_col" pos="0.38 -0.18 0.4" size="0.02 0.02 1.5" type="box" group="0" friction="1 0.005 0.0001"/>
      <geom name="shelf_leg_3_col" pos="-0.38 0.18 0.4" size="0.02 0.02 1.5" type="box" group="0" friction="1 0.005 0.0001"/>
      <geom name="shelf_leg_4_col" pos="0.38 0.18 0.4" size="0.02 0.02 1.5" type="box" group="0" friction="1 0.005 0.0001"/>

      <!-- 3层隔板 (碰撞) - 让盒子能放在上面 -->
      <!-- 底层 (离地0.02) -->
      <geom name="shelf_board_1_col" pos="0 0 0.5" size="0.4 0.2 0.02" type="box" group="0" friction="1 0.005 0.0001"/>
      <!-- 中层 (离地0.4) -->
      <geom name="shelf_board_2_col" pos="0 0 1.0" size="0.4 0.2 0.02" type="box" group="0" friction="1 0.005 0.0001"/>
      <!-- 顶层 (离地0.78) -->
      <geom name="shelf_board_3_col" pos="0 0 1.5" size="0.4 0.2 0.02" type="box" group="0" friction="1 0.005 0.0001"/>

      <!-- === 2. 视觉体 (Visual) - 只看不碰 === -->
      <geom pos="-0.38 -0.18 0.4" size="0.02 0.02 1.5" type="box" conaffinity="0" contype="0" group="1" name="shelf_leg_1_vis" material="shelf_legs_metal"/>
      <geom pos="0.38 -0.18 0.4" size="0.02 0.02 1.5" type="box" conaffinity="0" contype="0" group="1" name="shelf_leg_2_vis" material="shelf_legs_metal"/>
      <geom pos="-0.38 0.18 0.4" size="0.02 0.02 1.5" type="box" conaffinity="0" contype="0" group="1" name="shelf_leg_3_vis" material="shelf_legs_metal"/>
      <geom pos="0.38 0.18 0.4" size="0.02 0.02 1.5" type="box" conaffinity="0" contype="0" group="1" name="shelf_leg_4_vis" material="shelf_legs_metal"/>

      <geom pos="0 0 0.5" size="0.4 0.2 0.02" type="box" conaffinity="0" contype="0" group="1" name="shelf_board_1_vis" material="shelf_ceramic"/>
      <geom pos="0 0 1.0" size="0.4 0.2 0.02" type="box" conaffinity="0" contype="0" group="1" name="shelf_board_2_vis" material="shelf_ceramic"/>
      <geom pos="0 0 1.5" size="0.4 0.2 0.02" type="box" conaffinity="0" contype="0" group="1" name="shelf_board_3_vis" material="shelf_ceramic"/>
      
      <!-- 可选：添加一个 site 标记货架中心顶部，方便定位 -->
      <site pos="0 0 0.8" name="shelf_top" size="0.001 0.001 0.001" rgba="1 0 0 1"/>
    </body>
    <!-- ================= 货架结束 ================= -->

    <!-- Light (不变) -->
    <light pos="1.0 1.0 1.5" dir="-0.2 -0.2 -1" specular="0.3 0.3 0.3" directional="true" castshadow="false"/>
    

    <!-- side view -->
    <camera mode="fixed" name="sideview" pos="2.5 0 1.0" quat="0.707 0 0.707 0"/>
    <!-- bird view -->
    <camera mode="fixed" name="birdview" pos="-0.2 0 3.0" quat="0.7071 0 0 0.7071"/>
    <!-- agent view -->
    <camera mode="fixed" name="agentview" pos="0.5 0 1.35" quat="0.653 0.271 0.271 0.653"/>
    <!-- front view-->
    <camera mode="fixed" name="frontview" pos="-0 3.0 1.5" quat="-0.0251 -0.0278 0.6217 0.7824" />
  </worldbody>
</mujoco>